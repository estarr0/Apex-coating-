<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Colours — Apex Coating (EA) Ltd</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="style.css" />
</head>
<body data-page="colours">

  <!-- SIDEBAR -->
  <nav class="sidebar">
    <div class="logo-badge">
      <img src="images/apex-logo.png" alt="Apex Coating (EA) Ltd" />
    </div>
    <div class="logo-badge logo-badge-premier">
      <img src="images/premier-coat-logo.png" alt="Premier Coat" />
    </div>
    <div class="brand-stripe"></div>
    <div class="nav-links">
      <a class="nav-btn" data-page="home" href="index.html">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span class="tooltip">Home</span>
      </a>
      <a class="nav-btn" data-page="colours" href="colours.html">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="13.5" cy="6.5" r=".5"/><circle cx="17.5" cy="10.5" r=".5"/><circle cx="8.5" cy="7.5" r=".5"/><circle cx="6.5" cy="12.5" r=".5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>
        <span class="tooltip">Colours</span>
      </a>
      <a class="nav-btn" data-page="products" href="products.html">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" y1="22" x2="12" y2="12"/></svg>
        <span class="tooltip">Products</span>
      </a>
      <a class="nav-btn" data-page="cart" href="cart.html">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 2-1.58l1.65-7.42H5.12"/></svg>
        <span class="tooltip">Cart</span>
        <span id="cartBadge" class="cart-badge" hidden>0</span>
      </a>
      <a class="nav-btn" data-page="learn" href="learn.html">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        <span class="tooltip">Learn</span>
      </a>
      <a class="nav-btn" data-page="contact" href="contact.html">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <span class="tooltip">Contact</span>
      </a>
    </div>
    <button id="themeToggle" class="nav-btn theme-btn">
      <svg id="iconMoon" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
      <svg id="iconSun" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" hidden><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
    </button>
  </nav>

  <main>
    <section class="section">
      <p class="eyebrow">Colour Centre</p>
      <h2 class="display section-title">Pick shades, get a custom mix</h2>
      <p class="section-sub">
        Tap a colour family to browse shades, add up to five to your mix, then choose the
        product, pack size and quantity for your custom blend.
      </p>

      <div id="groupGrid" class="group-grid"></div>
      <div id="shadePanel" class="shade-panel" hidden></div>

      <div class="mixer">
        <div class="mixer-hero">
          <div class="blend-compare">
            <div id="blendSwatch" class="blend-swatch"></div>
            <span class="approx-symbol">≈</span>
            <div id="matchSwatch" class="match-swatch"></div>
          </div>
          <div class="mixer-hero-text">
            <p class="mixer-hero-label">Closest shade match</p>
            <p id="mixMatch" class="mix-match">Add up to 5 shades to preview your blend</p>
            <p id="mixComponents" class="mix-components"></p>
          </div>
        </div>

        <div id="pickTray" class="pick-tray"></div>

        <div class="mixer-controls">
          <label>
            Product
            <select id="productSelect"></select>
          </label>
          <label>
            Pack size
            <select id="sizeSelect"></select>
          </label>
          <label>
            Quantity
            <div class="qty-stepper">
              <button id="qtyMinus" type="button">−</button>
              <span id="qtyValue">1</span>
              <button id="qtyPlus" type="button">+</button>
            </div>
          </label>
          <div class="mixer-price">
            <span class="mixer-price-label">Unit price</span>
            <span id="unitPrice" class="mixer-price-value">—</span>
          </div>
        </div>

        <div class="mixer-actions">
          <button id="addToCartBtn" class="btn btn-primary" disabled>Add mix to cart</button>
          <button id="clearMixBtn" class="btn btn-ghost">Clear mix</button>
        </div>
      </div>
    </section>
  </main>

  <script src="script.js"></script>
</body>
</html>
